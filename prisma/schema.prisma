generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth (NextAuth.js) ──────────────────────────────────────

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  passwordHash  String    @map("password_hash")
  name          String?
  role          UserRole  @default(COMPANY)
  emailVerified DateTime? @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts  Account[]
  sessions  Session[]
  company   Company?
  candidate Candidate?

  @@map("users")
}

enum UserRole {
  COMPANY
  CANDIDATE
}

model Account {
  id                String  @id @default(uuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Company Profile ─────────────────────────────────────────

model Company {
  id                    String                     @id @default(uuid())
  userId                String                     @unique @map("user_id")
  email                 String                     @unique
  companyName           String?                    @map("company_name")
  companyWebsite        String?                    @map("company_website")
  companySize           CompanySize?               @map("company_size")
  industry              String?
  monthlyBudgetMin      Int?                       @map("monthly_budget_min") // in USD
  verified              Boolean                    @default(false)
  verifiedAt            DateTime?                  @map("verified_at")
  verificationStatus    CompanyVerificationStatus  @default(UNVERIFIED) @map("verification_status")
  verificationScore     Int?                       @map("verification_score")    // 0-100
  verificationSummary   String?                    @map("verification_summary")  @db.Text
  verificationDetails   String[]                   @default([]) @map("verification_details")
  verifiedVia           String?                    @map("verified_via")          // "ai", "admin", "email_domain"
  credits               Int                        @default(0)
  freeUnlocksUsed       Int                        @default(0) @map("free_unlocks_used")
  stripeCustomerId      String?                    @unique @map("stripe_customer_id")
  subscriptionId        String?                    @unique @map("subscription_id")
  subscriptionTier      SubscriptionTier?          @map("subscription_tier")
  subscriptionStatus    SubscriptionStatus?        @map("subscription_status")
  monthlyUnlocksUsed    Int                        @default(0) @map("monthly_unlocks_used")
  monthlyUnlocksLimit   Int?                       @map("monthly_unlocks_limit")
  billingCycleStart     DateTime?                  @map("billing_cycle_start")
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  unlocks         Unlock[]
  creditPurchases CreditPurchase[]
  savedCandidates SavedCandidate[]
  ratings         CompanyRating[]
  jobs            Job[]

  @@map("companies")
}

enum CompanySize {
  SOLO        // 1 person
  SMALL       // 2-10
  MEDIUM      // 11-50
  LARGE       // 51-200
  ENTERPRISE  // 200+
}

enum CompanyVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum SubscriptionTier {
  STARTER    // $149/mo, 10 unlocks
  GROWTH     // $299/mo, 25 unlocks
  ENTERPRISE // $599/mo, unlimited
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// ─── Candidates ────────────────────────────────────────────

model Candidate {
  id           Int          @id @default(autoincrement())
  userId       String?      @unique @map("user_id")
  name         String       // Display name, e.g., "Patricia M."
  fullName     String       @map("full_name")
  title        String
  avatar       String
  vertical     Vertical
  experience   Int
  availability Availability
  skills       String[]
  tools        String[]
  location     String
  rating       Float
  summary      String
  verified     Boolean      @default(false)
  verifiedDate DateTime?    @map("verified_date")
  vettingScore Int          @map("vetting_score")

  // Locked fields (revealed on unlock)
  email        String?
  phone        String?
  linkedIn     String?      @map("linked_in")
  videoUrl     String?      @map("video_url")
  englishScore Int?         @map("english_score")
  discProfile  String?      @map("disc_profile")
  salaryMin    Int?         @map("salary_min")  // monthly USD
  salaryMax    Int?         @map("salary_max")  // monthly USD
  salaryPeriod String?      @default("monthly") @map("salary_period")

  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  caseStudies     CaseStudy[]
  references      Reference[]
  vettingLayers   VettingLayerResult[]
  vettingProfile  VettingProfile?
  unlocks         Unlock[]
  savedBy         SavedCandidate[]
  companyRatings  CompanyRating[]
  jobApplications JobApplication[]

  @@map("candidates")
}

enum Vertical {
  ecommerce
  accounting
}

enum Availability {
  FULL_TIME @map("Full-time")
  PART_TIME @map("Part-time")
  CONTRACT  @map("Contract")
}

model CaseStudy {
  id          Int       @id @default(autoincrement())
  candidateId Int       @map("candidate_id")
  title       String
  outcome     String
  metrics     String?

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("case_studies")
}

model Reference {
  id          Int    @id @default(autoincrement())
  candidateId Int    @map("candidate_id")
  name        String
  company     String
  role        String
  quote       String

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("references")
}

// ─── Vetting Pipeline ──────────────────────────────────────

model VettingProfile {
  id           String        @id @default(uuid())
  candidateId  Int           @unique @map("candidate_id")
  status       VettingStatus @default(PENDING)
  overallScore Int           @default(0) @map("overall_score")
  startedAt    DateTime      @default(now()) @map("started_at")
  completedAt  DateTime?     @map("completed_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("vetting_profiles")
}

enum VettingStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  FAILED
}

model VettingLayerResult {
  id          String       @id @default(uuid())
  candidateId Int          @map("candidate_id")
  layer       VettingLayer
  score       Int
  passed      Boolean
  summary     String?
  details     String[]     @default([])
  resultJson  Json?        @map("result_json") // Full structured result
  completedAt DateTime?    @map("completed_at")
  createdAt   DateTime     @default(now()) @map("created_at")

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([candidateId, layer])
  @@map("vetting_layer_results")
}

enum VettingLayer {
  RESUME_ANALYSIS
  SCENARIO_ASSESSMENT
  VIDEO_INTERVIEW
  REFERENCE_CHECK
}

// ─── Unlocks & Credits ─────────────────────────────────────

model Unlock {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  candidateId Int      @map("candidate_id")
  contacted   Boolean  @default(false)
  unlockedAt  DateTime @default(now()) @map("unlocked_at")

  company   Company   @relation(fields: [companyId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@unique([companyId, candidateId])
  @@map("unlocks")
}

model CreditPurchase {
  id                  String       @id @default(uuid())
  companyId           String       @map("company_id")
  credits             Int
  amountCents         Int          @map("amount_cents")
  stripeSessionId     String?      @unique @map("stripe_session_id")
  stripePaymentIntent String?      @map("stripe_payment_intent")
  type                PurchaseType
  createdAt           DateTime     @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id])

  @@map("credit_purchases")
}

enum PurchaseType {
  CREDIT_PACK
  SUBSCRIPTION
}

model SavedCandidate {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  candidateId Int      @map("candidate_id")
  savedAt     DateTime @default(now()) @map("saved_at")

  company   Company   @relation(fields: [companyId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@unique([companyId, candidateId])
  @@map("saved_candidates")
}

// ─── Company Ratings (candidate feedback) ──────────────────

model CompanyRating {
  id          String   @id @default(uuid())
  companyId   String   @map("company_id")
  candidateId Int      @map("candidate_id")
  rating      Int      // 1-5
  fairOffer   Boolean  @map("fair_offer")
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  company   Company   @relation(fields: [companyId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@unique([companyId, candidateId])
  @@map("company_ratings")
}

// ─── Professional Applications ────────────────────────────

model Application {
  id          String            @id @default(uuid())
  fullName    String            @map("full_name")
  email       String
  phone       String?
  linkedInUrl String?           @map("linkedin_url")
  vertical    Vertical
  experience  Int
  resumeText  String?           @map("resume_text")
  skills      String[]
  bio         String?
  status      ApplicationStatus @default(PENDING)
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  @@map("applications")
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  APPROVED
  REJECTED
}

// ─── Jobs & Job Applications ──────────────────────────────

model Job {
  id            String       @id @default(uuid())
  companyId     String       @map("company_id")
  title         String
  description   String       @db.Text
  vertical      Vertical
  experienceMin Int          @default(5) @map("experience_min")
  experienceMax Int?         @map("experience_max")
  availability  Availability
  salaryMin     Int?         @map("salary_min")   // monthly USD
  salaryMax     Int?         @map("salary_max")   // monthly USD
  skills        String[]
  location      String?      @default("Remote")
  status        JobStatus    @default(DRAFT)
  expiresAt     DateTime?    @map("expires_at")
  publishedAt   DateTime?    @map("published_at")
  closedAt      DateTime?    @map("closed_at")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([status, publishedAt])
  @@index([companyId, status])
  @@map("jobs")
}

enum JobStatus {
  DRAFT
  OPEN
  CLOSED
}

model JobApplication {
  id          String               @id @default(uuid())
  jobId       String               @map("job_id")
  candidateId Int                  @map("candidate_id")
  coverLetter String?              @map("cover_letter") @db.Text
  status      JobApplicationStatus @default(PENDING)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")

  job       Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([candidateId, createdAt])
  @@map("job_applications")
}

enum JobApplicationStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  REJECTED
}
